{
  "author": "Roberto Pintos López <roberto.pintos.lopez@gmail.com>",
  "description": "General purpose memory for AI agents ",
  "devDependencies": {
    "@inversifyjs/eslint-plugin-require-extensions": "0.2.0",
    "@inversifyjs/foundation-eslint-config": "0.2.1",
    "@inversifyjs/foundation-prettier-config": "0.1.1",
    "@inversifyjs/foundation-typescript-config": "0.2.0",
    "@inversifyjs/foundation-vitest-config": "0.2.0",
    "turbo": "2.9.14"
  },
  "name": "root",
  "keywords": [
    "ai",
    "api",
    "client",
    "memory",
    "llm",
    "long-term-memory",
    "ravenmind"
  ],
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.1.1",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuaklabs/ravenmind.git"
  },
  "scripts": {
    "build": "turbo run build",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "prepare": "turbo telemetry disable",
    "test:integration": "turbo test:integration",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:mutation": "turbo run test:mutation --concurrency=25%",
    "test:uncommitted": "turbo run test:uncommitted --filter [HEAD]",
    "test:unit": "turbo run test:unit"
  },
  "type": "module"
}
