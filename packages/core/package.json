{
  "author": "Roberto Pintos López",
  "bugs": {
    "url": "https://github.com/cuaklabs/ravenmind/issues"
  },
  "dependencies": {
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "description": "Ravenmind core package",
  "devDependencies": {
    "@standard-schema/spec": "1.1.0",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "10.3.0",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "homepage": "https://github.com/cuaklabs/ravenmind",
  "keywords": [
    "ai",
    "core",
    "memory",
    "llm",
    "long-term-memory",
    "ravenmind",
    "typescript"
  ],
  "devEngines": {
    "node": "^24.10.0",
    "pnpm": "^10.13.1"
  },
  "license": "Apache-2.0",
  "module": "lib/esm/index.js",
  "exports": {
    ".": "./lib/esm/index.js",
    "./vector": "./lib/esm/vector/index.js"
  },
  "name": "@ravenmind/core",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuaklabs/ravenmind.git"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "rimraf lib",
    "format": "prettier --write ./src",
    "lint": "eslint ./src",
    "prebuild": "pnpm run build:clean",
    "test": "vitest run",
    "test:integration": "pnpm run test --project Integration",
    "test:coverage": "pnpm run test:unit --coverage",
    "test:uncommitted": "pnpm run test --changed=HEAD",
    "test:unit": "pnpm run test --project Unit"
  },
  "type": "module",
  "version": "0.0.0"
}
